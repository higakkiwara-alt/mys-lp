# ============================================================
# Authentication (REQUIRED for production)
# ============================================================
# Generate AUTH_SECRET with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="your-64-char-hex-secret"

# Admin password for the dashboard login
ADMIN_PASSWORD="your-strong-password-here"

# OPTIONAL: Enable TOTP/MFA for admin login
# 1. GET /api/auth/mfa-setup while logged in to generate a secret + QR code
# 2. Scan with an authenticator app (Google Authenticator, Authy, 1Password)
# 3. Set the secret here and redeploy — MFA is then enforced on every login
# TOTP_SECRET="BASE32ENCODEDTOTPSECRET"

# ============================================================
# Database
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/ai_salon_os"

# ============================================================
# Supabase
# ============================================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================================
# AI APIs
# ============================================================
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."

# ============================================================
# Google APIs
# ============================================================
GOOGLE_CLIENT_ID="your-client-id"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REFRESH_TOKEN="your-refresh-token"
GOOGLE_BUSINESS_ACCOUNT_ID="accounts/your-account-id"
GOOGLE_BUSINESS_LOCATION_ID="locations/your-location-id"
GOOGLE_MAPS_API_KEY="your-maps-api-key"

# ============================================================
# Instagram / Meta
# ============================================================
INSTAGRAM_ACCESS_TOKEN="your-instagram-access-token"
INSTAGRAM_BUSINESS_ACCOUNT_ID="your-account-id"

# REQUIRED: Must be set before registering the webhook with Meta
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
INSTAGRAM_VERIFY_TOKEN="your-random-verify-token"

META_APP_ID="your-meta-app-id"

# REQUIRED: Used to verify Instagram webhook signatures (X-Hub-Signature-256)
META_APP_SECRET="your-meta-app-secret"

# ============================================================
# LINE
# ============================================================
LINE_CHANNEL_ACCESS_TOKEN="your-line-channel-access-token"

# REQUIRED: Used to verify LINE webhook signatures (x-line-signature)
LINE_CHANNEL_SECRET="your-line-channel-secret"

# ============================================================
# WordPress
# ============================================================
WORDPRESS_URL="https://your-salon.com"
WORDPRESS_USERNAME="your-username"
WORDPRESS_APP_PASSWORD="your-app-password"

# ============================================================
# Optional services
# ============================================================
REMOVE_BG_API_KEY="your-remove-bg-key"

# ============================================================
# App Config
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# REQUIRED for production cron jobs
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="your-cron-secret"
