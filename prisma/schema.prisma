generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id          String      @id @default(cuid())
  content     String
  platforms   String[]
  status      PostStatus  @default(DRAFT)
  source      String?
  imageUrl    String?
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  expansions  Expansion[]
  analytics   PostAnalytics?
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

model Expansion {
  id         String   @id @default(cuid())
  postId     String
  platform   String
  content    String
  title      String?
  hashtags   String[]
  status     PostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt  DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model PostAnalytics {
  id          String @id @default(cuid())
  postId      String @unique
  likes       Int    @default(0)
  comments    Int    @default(0)
  shares      Int    @default(0)
  impressions Int    @default(0)
  clicks      Int    @default(0)
  updatedAt   DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Review {
  id          String       @id @default(cuid())
  googleId    String?      @unique
  authorName  String
  rating      Int
  text        String
  publishedAt DateTime
  aiReply     String?
  replied     Boolean      @default(false)
  repliedAt   DateTime?
  sentiment   String?
  createdAt   DateTime     @default(now())
}

model Keyword {
  id           String   @id @default(cuid())
  keyword      String
  currentRank  Int?
  previousRank Int?
  searchVolume Int?
  difficulty   Float?
  url          String?
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@unique([keyword])
}

model BlogPost {
  id           String   @id @default(cuid())
  title        String
  content      String
  excerpt      String?
  slug         String   @unique
  metaTitle    String?
  metaDesc     String?
  focusKeyword String?
  status       PostStatus @default(DRAFT)
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Competitor {
  id           String   @id @default(cuid())
  name         String
  placeId      String?  @unique
  url          String?
  area         String?
  category     String?
  createdAt    DateTime @default(now())

  snapshots CompetitorSnapshot[]
}

model CompetitorSnapshot {
  id            String   @id @default(cuid())
  competitorId  String
  rating        Float?
  reviewCount   Int?
  photoCount    Int?
  postCount     Int?
  rank          Int?
  snapshotDate  DateTime @default(now())

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
}

model BrainEntry {
  id         String     @id @default(cuid())
  title      String
  content    String
  type       BrainType
  tags       String[]
  source     String?
  embedding  Float[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum BrainType {
  VOICE_MEMO
  MEETING
  MANUAL
  LINE_MESSAGE
  IMAGE_DESC
  AI_PROPOSAL
  CUSTOMER_CARD
  STRATEGY
}

model DailyDigest {
  id           String   @id @default(cuid())
  date         DateTime @unique
  metrics      Json
  achievements String[]
  todayTasks   Json[]
  improvements String[]
  priorities   Json[]
  rawData      Json?
  createdAt    DateTime @default(now())
}

model MeoPost {
  id          String     @id @default(cuid())
  content     String
  imageUrl    String?
  type        MeoPostType @default(WHATS_NEW)
  startDate   DateTime?
  endDate     DateTime?
  status      PostStatus @default(DRAFT)
  googlePostId String?
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
}

enum MeoPostType {
  WHATS_NEW
  EVENT
  OFFER
  PRODUCT
}
